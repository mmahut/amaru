<?xml version='1.0' encoding='windows-1252'?>
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Id='*'
    Name='Amaru'
    UpgradeCode='5ED1B86D-18EF-4E2E-B1A1-847BD838C3F9'
    Manufacturer='PRAGMA'
    Language='1033'
    Codepage='1252'
    Version='$(var.Version)'>
    <Package
      Id='*'
      Keywords='Installer'
      Description='A fully open source Cardano node written in Rust.'
      Manufacturer='PRAGMA'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perUser'
      SummaryCodepage='1252'/>
    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>
    <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='Amaru Installation'/>
    <Property Id='DiskPrompt' Value='Amaru Installation'/>
    <Property Id='ARPNOMODIFY' Value='1'/>
    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='LocalAppDataFolder'>
        <Directory Id='APPLICATIONFOLDER' Name='Amaru'>
          <Component Id='Readme' Guid='D40ABDBB-6782-4648-8597-F92EC7B26CB1'>
            <File Id='ReadmeFile' Name='README.md' DiskId='1' Source='..\..\README.md' KeyPath='no'/>
            <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='Readme' Type='integer' Value='1' KeyPath='yes'/>
          </Component>
          <Component Id='Changelog' Guid='532FA8D6-65FA-468A-8F56-6819DE36567A'>
            <File Id='ChangelogFile' Name='CHANGELOG.md' DiskId='1' Source='..\..\CHANGELOG.md' KeyPath='no'/>
            <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='Changelog' Type='integer' Value='1' KeyPath='yes'/>
          </Component>
          <Component Id='License' Guid='4D6544F5-B3DD-45B8-8711-241ECA6048C2'>
            <File Id='LicenseFile' Name='LICENSE' DiskId='1' Source='..\..\LICENSE' KeyPath='no'/>
            <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='License' Type='integer' Value='1' KeyPath='yes'/>
          </Component>
          <Component Id='CleanupFolders' Guid='*'>
            <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='CleanupFolders' Type='integer' Value='1' KeyPath='yes'/>
            <RemoveFolder Id='RemoveInstallerFolder' Directory='Installer' On='uninstall'/>
            <RemoveFolder Id='RemoveCompletionsFolder' Directory='Completions' On='uninstall'/>
            <RemoveFolder Id='RemovePowerShellFolder' Directory='PowerShell' On='uninstall'/>
            <RemoveFolder Id='RemoveShareFolder' Directory='Share' On='uninstall'/>
            <RemoveFolder Id='RemoveBinFolder' Directory='Bin' On='uninstall'/>
            <RemoveFolder Id='RemoveApplicationFolder' Directory='APPLICATIONFOLDER' On='uninstall'/>
          </Component>
          <Directory Id='Bin' Name='bin'>
            <Component Id='Path' Guid='B098A544-96F1-46D8-A941-5E22F82EFADD'>
              <Environment
                Id='PATH'
                Name='PATH'
                Value='[Bin]'
                Permanent='no'
                Part='last'
                Action='set'
                System='no'/>
              <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='Path' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
            <Component Id='AmaruBinary' Guid='9A4818B2-B370-4A32-A475-B2B80F815512'>
              <File Id='AmaruExe' Name='amaru.exe' DiskId='1' Source='$(var.CargoTargetBinDir)\amaru.exe' KeyPath='no'/>
              <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='AmaruBinary' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
          </Directory>
          <Directory Id='Share' Name='share'>
            <Directory Id='PowerShell' Name='powershell'>
              <Directory Id='Completions' Name='completions'>
                <Component Id='PowerShellCompletion' Guid='2666865E-CFC8-43E1-B30F-90301803AFBA'>
                  <File
                    Id='PowerShellCompletionFile'
                    Name='amaru.ps1'
                    DiskId='1'
                    Source='..\..\dist\share\powershell\completions\amaru.ps1'
                    KeyPath='no'/>
                  <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='PowerShellCompletion' Type='integer' Value='1' KeyPath='yes'/>
                </Component>
              </Directory>
            </Directory>
            <Directory Id='Installer' Name='installer'>
              <Component Id='RegisterCompletionScript' Guid='5FA9094C-0F57-4C26-9521-06942C2DD55B'>
                <File
                  Id='RegisterCompletionScriptFile'
                  Name='register-completion.ps1'
                  DiskId='1'
                  Source='wix\register-completion.ps1'
                  KeyPath='no'/>
                <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='RegisterCompletionScript' Type='integer' Value='1' KeyPath='yes'/>
              </Component>
              <Component Id='UnregisterCompletionScript' Guid='1FEB67A0-EB8F-4BCC-B80E-DD3B082450A0'>
                <File
                  Id='UnregisterCompletionScriptFile'
                  Name='unregister-completion.ps1'
                  DiskId='1'
                  Source='wix\unregister-completion.ps1'
                  KeyPath='no'/>
                <RegistryValue Root='HKCU' Key='Software\PRAGMA\Amaru\Components' Name='UnregisterCompletionScript' Type='integer' Value='1' KeyPath='yes'/>
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </Directory>
    <Feature
      Id='Binaries'
      Title='Application'
      Description='Installs Amaru and its bundled command-line assets.'
      Level='1'
      ConfigurableDirectory='APPLICATIONFOLDER'
      AllowAdvertise='no'
      Display='expand'
      Absent='disallow'>
      <ComponentRef Id='AmaruBinary'/>
      <ComponentRef Id='Readme'/>
      <ComponentRef Id='Changelog'/>
      <ComponentRef Id='License'/>
      <ComponentRef Id='CleanupFolders'/>
      <ComponentRef Id='PowerShellCompletion'/>
      <ComponentRef Id='RegisterCompletionScript'/>
      <ComponentRef Id='UnregisterCompletionScript'/>
      <Feature
        Id='Environment'
        Title='PATH Environment Variable'
        Description='Add the install location of the Amaru executable to the PATH user environment variable.'
        Level='1'
        Absent='allow'>
        <ComponentRef Id='Path'/>
      </Feature>
    </Feature>
    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
    <Property Id='ARPHELPLINK' Value='https://github.com/pragma-org/amaru'/>
    <UIRef Id='WixUI_FeatureTree'/>
    <SetProperty
      Id='RegisterPowerShellCompletion'
      Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "[#RegisterCompletionScriptFile]" -InstallRoot "[APPLICATIONFOLDER]"'
      Sequence='execute'
      Before='RegisterPowerShellCompletion'/>
    <CustomAction
      Id='RegisterPowerShellCompletion'
      BinaryKey='WixCA'
      DllEntry='WixQuietExec64'
      Execute='deferred'
      Return='check'
      Impersonate='yes'/>
    <SetProperty
      Id='UnregisterPowerShellCompletion'
      Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "[#UnregisterCompletionScriptFile]"'
      Sequence='execute'
      Before='UnregisterPowerShellCompletion'/>
    <CustomAction
      Id='UnregisterPowerShellCompletion'
      BinaryKey='WixCA'
      DllEntry='WixQuietExec64'
      Execute='deferred'
      Return='check'
      Impersonate='yes'/>
    <InstallExecuteSequence>
      <Custom Action='RegisterPowerShellCompletion' After='InstallFiles'>NOT REMOVE</Custom>
      <Custom Action='UnregisterPowerShellCompletion' Before='RemoveFiles'>REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>
  </Product>
</Wix>
