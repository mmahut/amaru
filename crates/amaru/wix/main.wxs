<?xml version='1.0' encoding='windows-1252'?>
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Id='*'
    Name='Amaru'
    UpgradeCode='5ED1B86D-18EF-4E2E-B1A1-847BD838C3F9'
    Manufacturer='PRAGMA'
    Language='1033'
    Codepage='1252'
    Version='$(var.Version)'>
    <Package
      Id='*'
      Keywords='Installer'
      Description='A fully open source Cardano node written in Rust.'
      Manufacturer='PRAGMA'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perUser'
      SummaryCodepage='1252'/>
    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>
    <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='Amaru Installation'/>
    <Property Id='DiskPrompt' Value='Amaru Installation'/>
    <Property Id='ARPNOMODIFY' Value='1'/>
    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='LocalAppDataFolder'>
        <Directory Id='LocalProgramsFolder' Name='Programs'>
          <Directory Id='APPLICATIONFOLDER' Name='Amaru'>
            <Component Id='Readme' Guid='*'>
              <File Id='ReadmeFile' Name='README.md' DiskId='1' Source='..\..\README.md' KeyPath='yes'/>
            </Component>
            <Component Id='Changelog' Guid='*'>
              <File Id='ChangelogFile' Name='CHANGELOG.md' DiskId='1' Source='..\..\CHANGELOG.md' KeyPath='yes'/>
            </Component>
            <Component Id='License' Guid='*'>
              <File Id='LicenseFile' Name='LICENSE' DiskId='1' Source='..\..\LICENSE' KeyPath='yes'/>
            </Component>
            <Directory Id='Bin' Name='bin'>
              <Component Id='Path' Guid='B098A544-96F1-46D8-A941-5E22F82EFADD' KeyPath='yes'>
                <Environment
                  Id='PATH'
                  Name='PATH'
                  Value='[Bin]'
                  Permanent='no'
                  Part='last'
                  Action='set'
                  System='no'/>
              </Component>
              <Component Id='AmaruBinary' Guid='*'>
                <File Id='AmaruExe' Name='amaru.exe' DiskId='1' Source='$(var.CargoTargetBinDir)\amaru.exe' KeyPath='yes'/>
              </Component>
            </Directory>
            <Directory Id='Share' Name='share'>
              <Directory Id='PowerShell' Name='powershell'>
                <Directory Id='Completions' Name='completions'>
                  <Component Id='PowerShellCompletion' Guid='*'>
                    <File
                      Id='PowerShellCompletionFile'
                      Name='amaru.ps1'
                      DiskId='1'
                      Source='..\..\dist\share\powershell\completions\amaru.ps1'
                      KeyPath='yes'/>
                  </Component>
                </Directory>
              </Directory>
              <Directory Id='Installer' Name='installer'>
                <Component Id='RegisterCompletionScript' Guid='*'>
                  <File
                    Id='RegisterCompletionScriptFile'
                    Name='register-completion.ps1'
                    DiskId='1'
                    Source='wix\register-completion.ps1'
                    KeyPath='yes'/>
                </Component>
                <Component Id='UnregisterCompletionScript' Guid='*'>
                  <File
                    Id='UnregisterCompletionScriptFile'
                    Name='unregister-completion.ps1'
                    DiskId='1'
                    Source='wix\unregister-completion.ps1'
                    KeyPath='yes'/>
                </Component>
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </Directory>
    <Feature
      Id='Binaries'
      Title='Application'
      Description='Installs Amaru and its bundled command-line assets.'
      Level='1'
      ConfigurableDirectory='APPLICATIONFOLDER'
      AllowAdvertise='no'
      Display='expand'
      Absent='disallow'>
      <ComponentRef Id='AmaruBinary'/>
      <ComponentRef Id='Readme'/>
      <ComponentRef Id='Changelog'/>
      <ComponentRef Id='License'/>
      <ComponentRef Id='PowerShellCompletion'/>
      <ComponentRef Id='RegisterCompletionScript'/>
      <ComponentRef Id='UnregisterCompletionScript'/>
      <Feature
        Id='Environment'
        Title='PATH Environment Variable'
        Description='Add the install location of the Amaru executable to the PATH user environment variable.'
        Level='1'
        Absent='allow'>
        <ComponentRef Id='Path'/>
      </Feature>
    </Feature>
    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
    <Property Id='ARPHELPLINK' Value='https://github.com/pragma-org/amaru'/>
    <UIRef Id='WixUI_FeatureTree'/>
    <SetProperty
      Id='RegisterPowerShellCompletion'
      Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "[#RegisterCompletionScriptFile]" -InstallRoot "[APPLICATIONFOLDER]"'
      Sequence='execute'
      Before='RegisterPowerShellCompletion'/>
    <CustomAction
      Id='RegisterPowerShellCompletion'
      BinaryKey='WixCA'
      DllEntry='WixQuietExec64'
      Execute='deferred'
      Return='check'
      Impersonate='yes'/>
    <SetProperty
      Id='UnregisterPowerShellCompletion'
      Value='"[System64Folder]WindowsPowerShell\v1.0\powershell.exe" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "[#UnregisterCompletionScriptFile]"'
      Sequence='execute'
      Before='UnregisterPowerShellCompletion'/>
    <CustomAction
      Id='UnregisterPowerShellCompletion'
      BinaryKey='WixCA'
      DllEntry='WixQuietExec64'
      Execute='deferred'
      Return='check'
      Impersonate='yes'/>
    <InstallExecuteSequence>
      <Custom Action='RegisterPowerShellCompletion' After='InstallFiles'>NOT REMOVE</Custom>
      <Custom Action='UnregisterPowerShellCompletion' Before='RemoveFiles'>REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>
  </Product>
</Wix>
